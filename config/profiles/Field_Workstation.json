{
  "name": "Field_Workstation",
  "description": "Optimized for mobile/remote staff and laptops. Battery-aware power settings, offline-tolerant, VPN auto-connect, reduced sync activity.",
  "settings": {
    "power_mode": "Balanced",
    "visual_effects": "Balanced",
    "startup_apps": {
      "disable": ["OneDrive", "Skype", "Discord", "Spotify", "SteamBootstrapper"],
      "enable": ["WindowsDefender", "VPNClient", "Teams", "BitLocker"]
    },
    "taskbar": {
      "hide_search_box": false,
      "hide_task_view": false,
      "hide_cortana": true,
      "hide_news_interests": true,
      "small_icons": false
    },
    "file_explorer": {
      "show_file_extensions": true,
      "hide_recent_files": false,
      "hide_frequent_folders": false,
      "show_hidden_files": false,
      "launch_to_this_pc": true
    },
    "notifications": {
      "reduce_notifications": false,
      "focus_assist": "Off",
      "disable_tips": true,
      "disable_suggestions": true
    },
    "windows_update": {
      "pause_days": 14,
      "defer_feature_updates_days": 180,
      "active_hours_start": 8,
      "active_hours_end": 20,
      "metered_connection_pause": true
    },
    "network": {
      "disable_ipv6": false,
      "dns_servers": ["8.8.8.8", "8.8.4.4"],
      "vpn_auto_connect": true,
      "wifi_sense_disable": true
    },
    "defender": {
      "exclusion_paths": ["C:\\IT_Tools\\", "C:\\Scripts\\"]
    },
    "privacy": {
      "disable_telemetry": true,
      "disable_advertising_id": true,
      "disable_location": false
    },
    "battery": {
      "critical_battery_action": "hibernate",
      "low_battery_threshold": 10,
      "sleep_on_battery_minutes": 15,
      "hibernate_on_battery_minutes": 60
    }
  }
}

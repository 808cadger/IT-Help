{
  "name": "High_Performance",
  "description": "Optimized for power users, engineers, and CAD/rendering workstations. Maximum CPU/GPU performance, minimal visual effects, aggressive startup cleanup.",
  "settings": {
    "power_mode": "Best_Performance",
    "visual_effects": "Performance",
    "startup_apps": {
      "disable": ["OneDrive", "Teams", "Skype", "Discord", "Spotify", "SteamBootstrapper",
                  "AdobeGCInvoker", "Cortana", "WindowsSearch"],
      "enable": ["WindowsDefender", "VPNClient", "NvidiaDisplay", "AMDRyzenMaster"]
    },
    "taskbar": {
      "hide_search_box": true,
      "hide_task_view": true,
      "hide_cortana": true,
      "hide_news_interests": true,
      "small_icons": true
    },
    "file_explorer": {
      "show_file_extensions": true,
      "hide_recent_files": true,
      "hide_frequent_folders": true,
      "show_hidden_files": true,
      "launch_to_this_pc": true
    },
    "notifications": {
      "reduce_notifications": true,
      "focus_assist": "Alarms_Only",
      "disable_tips": true,
      "disable_suggestions": true
    },
    "windows_update": {
      "pause_days": 30,
      "defer_feature_updates_days": 365,
      "active_hours_start": 6,
      "active_hours_end": 22
    },
    "network": {
      "disable_ipv6": true,
      "dns_servers": ["1.1.1.1", "1.0.0.1"]
    },
    "defender": {
      "exclusion_paths": [
        "C:\\IT_Tools\\", "C:\\Scripts\\", "C:\\Temp\\",
        "C:\\Program Files\\Autodesk\\",
        "C:\\Program Files\\SOLIDWORKS Corp\\",
        "C:\\Program Files (x86)\\Microsoft Visual Studio\\"
      ]
    },
    "privacy": {
      "disable_telemetry": true,
      "disable_advertising_id": true,
      "disable_location": true
    },
    "memory": {
      "disable_superfetch": false,
      "large_system_cache": true,
      "disable_paging_executive": true
    }
  }
}
